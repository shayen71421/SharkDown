# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
# Homepage URL: https://shark-down.vercel.app
# Callback URL: https://shark-down.vercel.app/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public env (shipped to browser, keep non-sensitive only)
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Redis (Vercel KV or Official Redis for Vercel)
# Vercel KV injects: KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN
# Official Redis injects: REDIS_URL, REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
# Falls back to in-memory store when neither is set (local dev)
KV_URL=
REDIS_URL=
